{
    "permissions": {
        "allow": [
            "Bash(git status *)",
            "Bash(git diff *)",
            "Bash(./gradlew *)",
            "Bash(cd backend && ./gradlew *)"
        ],
        "ask": [
            "Bash(git push *)",
            "Bash(gh pr merge *)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(git push origin main)",
            "Bash(curl *)",
            "Bash(wget *)"
        ]
    }
}