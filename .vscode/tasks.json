{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dynamodb-local: up",
      "type": "shell",
      "command": "docker compose up -d dynamodb-local",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "dynamodb-local: create-table",
